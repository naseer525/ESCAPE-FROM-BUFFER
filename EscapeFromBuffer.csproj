      <TargetFramework>net472</TargetFramework>
      <UseWindowsForms>true</UseWindowsForms>
      <RootNamespace>EscapeFromBuffer</RootNamespace>
      <AssemblyName>EscapeFromBuffer</AssemblyName>
      <AssemblyTitle>Escape From Buffer</AssemblyTitle>
